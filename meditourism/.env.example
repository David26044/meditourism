# Copy this file to .env for local development.
# Do not commit .env.

# Database used by docker-compose.yml
POSTGRES_VERSION=16
POSTGRES_CONTAINER_NAME=meditourism_postgres
POSTGRES_USER=meditourism
POSTGRES_PASSWORD=change_me_local_db_password
POSTGRES_DB=meditourism
POSTGRES_PORT=5432

# Spring datasource used by the API
SPRING_DATASOURCE_URL=jdbc:postgresql://localhost:5432/meditourism
SPRING_DATASOURCE_USERNAME=meditourism
SPRING_DATASOURCE_PASSWORD=change_me_local_db_password

# JWT signing secret. Use a long random value in shared/dev/prod environments.
JWT_SECRET=change_me_to_a_long_random_secret_at_least_32_chars

# Public URLs included in auth emails
APP_EMAIL_VERIFICATION_URL=http://localhost:8080/system/api/auth/verify-email
APP_FRONTEND_RESET_PASSWORD_URL=http://localhost:8080/system/api/auth/change-password

# Mail configuration. Leave empty locally if you do not need to send emails.
SPRING_MAIL_HOST=smtp.gmail.com
SPRING_MAIL_PORT=587
SPRING_MAIL_USERNAME=
SPRING_MAIL_PASSWORD=
SPRING_MAIL_SSL_TRUST=smtp.gmail.com
